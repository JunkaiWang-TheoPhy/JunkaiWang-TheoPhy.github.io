{
  "version": 1,
  "groups": {
    "eng": "G_eng",
    "journal": "G_journal",
    "science": "G_science",
    "packaging": "G_packaging"
  },
  "reviewProfile": {
    "defaultLanguage": "zh",
    "allowedLanguages": ["zh", "en"],
    "switchToEnglishOnRequest": true,
    "promptInjectionPlaceholder": "{{JOURNAL_RULES}}",
    "judgeRequiredOutputs": [
      "positioning_gaps",
      "banned_phrase_hits",
      "derivation_missing_items",
      "allowed_next_actions"
    ],
    "writerRequiredOutputs": [
      "positioning_paragraph_update",
      "contribution_bullets_update",
      "approximation_validity_sentences",
      "das_runin_block_update"
    ],
    "languageQualityPolicy": {
      "zh": [
        "Topic framing matches target-journal scholarly scope and contribution level.",
        "Section structure, paragraph logic, and argument flow meet journal-style expectations.",
        "Terminology, notation narration, and academic tone are precise and consistent.",
        "Claims remain evidence-backed; no colloquial or promotional wording."
      ],
      "en": [
        "Use English only when explicitly requested by user/task policy.",
        "When switched, preserve technical meaning and citation consistency."
      ]
    },
    "reviewHardChecks": [
      "zh_journal_quality",
      "english_on_request"
    ]
  },
  "journals": {
    "PRL": {
      "displayName": "Physical Review Letters",
      "skeleton": [
        "Minimal main text",
        "Run-in headings when needed",
        "Supplemental Material for long derivations"
      ],
      "metrics": {
        "positioning": {
          "minReferencesTotal": 15,
          "minRecentResearchRefs15y": 6,
          "recentRefRatioMin": 0.3,
          "researchRefRatioMin": 0.7,
          "coreClaimsPriorworkAnchorMin": 0.8
        },
        "presentation": {
          "bannedPhrasesInMainText": [
            "round-",
            "ledger",
            "ablation",
            "adversarial",
            "machine precision",
            "MAE",
            "slope spread",
            "stress test"
          ]
        },
        "derivationClosure": {
          "symbolDefinitionCoverageMin": 0.95,
          "newCriteriaMustDefineScope": true,
          "approximationsNeedDimensionlessConditions": true
        }
      },
      "promptPolicy": {
        "judge": {
          "mustCheck": [
            "Count total/recent/research references and map core claims to prior-work anchors",
            "Scan banned process words in main text only and mark exact hit locations",
            "Check approximation validity sentences: condition + omitted term + applicability range",
            "If positioning fails, cap novelty/science confidence and force repair-only next actions"
          ],
          "mustOutput": [
            "positioning_gaps",
            "banned_phrase_hits",
            "derivation_missing_items",
            "allowed_next_actions"
          ]
        },
        "writer": {
          "mustDo": [
            "Add or repair one <=120-word Known-Gap-Increment positioning paragraph in Introduction",
            "Provide 2-3 verifiable contribution bullets without hype adjectives",
            "For each approximation, add one sentence with validity condition and neglected term",
            "Keep Data availability as PRL run-in heading and move process/audit wording to SM or repo docs"
          ],
          "forbiddenInMainText": [
            "round-",
            "ledger",
            "ablation",
            "adversarial",
            "machine precision",
            "MAE",
            "slope spread",
            "stress test"
          ]
        }
      },
      "languagePolicy": {
        "defaultLanguage": "zh",
        "allowedLanguages": ["zh", "en"],
        "switchToEnglishOnRequest": true,
        "zhQualityBar": "Chinese manuscripts must keep PRL-grade information density, concise argument flow, and formal academic tone."
      },
      "artifacts": [
        "main.pdf",
        "supplement.pdf or supplement.tex",
        "vector figures",
        "metadata.json"
      ],
      "gates": {
        "eng": [
          { "key": "compile", "label": "latexmk -pdf passes" },
          { "key": "chinese_requires_ctex", "label": "If Chinese appears: use ctex package (forbid xeCJK/CJK)" },
          { "key": "no_raw_tex_in_chat", "label": "Do not output raw .tex in chat; write files directly" },
          { "key": "refs_clean", "label": "No undefined references" },
          { "key": "lint_clean", "label": "Lint/format checks pass" },
          { "key": "repro_scripts", "label": "Repro scripts executable" }
        ],
        "journal": [
          { "key": "title_case", "label": "Title uses APS title case" },
          { "key": "abstract_char_600", "label": "Abstract <= 600 chars" },
          { "key": "abstract_one_paragraph", "label": "Abstract is a single paragraph and self-contained" },
          { "key": "abstract_no_numbered_refs", "label": "Abstract has no numbered references/citation labels" },
          { "key": "abstract_no_display_eq_or_tables", "label": "Abstract contains no display equations or tables" },
          { "key": "word_limit_3750", "label": "Main text <= 3750 words" },
          { "key": "runin_or_none_headings", "label": "Main text uses run-in headings or no headings (no freestanding section heads)" },
          { "key": "zh_journal_quality", "label": "If Chinese is used, topic/format/style meet PRL scholarly standards" },
          { "key": "english_on_request", "label": "Switch to English only when explicitly requested" },
          { "key": "das_runin", "label": "Data availability run-in heading used" },
          { "key": "das_runin_format", "label": "Data availability follows run-in format \"Data availability— ...\"" },
          { "key": "appendix_after_refs", "label": "Appendix is in end matter after references" },
          { "key": "positioning_known_gap_increment", "label": "Introduction states Known -> Gap -> Increment with explicit prior-work comparison" },
          { "key": "core_claims_priorwork_anchor", "label": "Core claims are anchored to equations/figures and prior-work citations" },
          { "key": "recent_research_refs_min", "label": "Recent research references (<=15y) reach profile minimum" },
          { "key": "research_refs_ratio", "label": "Research-paper references dominate over textbook/monograph references" },
          { "key": "banned_process_language_main_text", "label": "Main text avoids process/audit ML wording (move to SM/repo)" },
          { "key": "sm_referenced", "label": "Supplemental Material referenced in main text" }
        ],
        "science": [
          { "key": "claims_evidence_trace", "label": "Claims map to explicit evidence" },
          { "key": "error_budget", "label": "Uncertainties and error budget documented" },
          { "key": "controls_or_baselines", "label": "Controls/baselines included" },
          { "key": "scope_limits", "label": "Applicability domain and limits stated" },
          { "key": "derivation_conditions_stated", "label": "Key approximations include explicit dimensionless validity conditions" },
          { "key": "new_criteria_defined_scoped", "label": "Any new criterion has parameter definitions and scope/regime statement" },
          { "key": "symbol_definition_coverage", "label": "New symbols are defined at first use with near-complete coverage" },
          { "key": "assumptions_and_omitted_terms", "label": "Derivations identify assumptions and omitted terms explicitly" }
        ],
        "packaging": [
          { "key": "main_pdf", "label": "main.pdf generated" },
          { "key": "supplement_pdf_or_tex", "label": "Supplement artifact ready" },
          { "key": "figures_vector", "label": "Figure assets packaged" },
          { "key": "metadata_json", "label": "metadata.json contains counts and checks" },
          { "key": "supplement_derivation_pointers", "label": "Supplement contains explicit pointers for long derivations referenced in main text" }
        ]
      }
    },
